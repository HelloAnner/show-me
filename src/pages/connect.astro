---
import Page from '@layouts/Page.astro'
import { db, schema } from '@db/index'
import { eq } from 'drizzle-orm'

const contactRow = db.select().from(schema.siteInfo).where(eq(schema.siteInfo.key, 'contact')).get()
const contact = contactRow ? JSON.parse(contactRow.value as string) : {}
---

<Page title="Connect" description="联系方式">
  <h1 class="font-display text-4xl font-bold tracking-tight mb-4">Connect</h1>
  <p class="text-muted mb-12">如果你觉得我们可能聊得来。</p>

  <div class="space-y-4">
    {contact.github && (
      <a href={contact.github} target="_blank" rel="noopener" class="group flex items-center gap-3 py-3 border-b border-ink/5">
        <span class="font-medium">GitHub</span>
        <span class="text-sm text-muted group-hover:text-accent transition-colors">{contact.github}</span>
      </a>
    )}
    {contact.email && (
      <a href={`mailto:${contact.email}`} class="group flex items-center gap-3 py-3 border-b border-ink/5">
        <span class="font-medium">Email</span>
        <span class="text-sm text-muted group-hover:text-accent transition-colors">{contact.email}</span>
      </a>
    )}
    {contact.twitter && (
      <a href={contact.twitter} target="_blank" rel="noopener" class="group flex items-center gap-3 py-3 border-b border-ink/5">
        <span class="font-medium">Twitter</span>
        <span class="text-sm text-muted group-hover:text-accent transition-colors">{contact.twitter}</span>
      </a>
    )}
  </div>
</Page>
