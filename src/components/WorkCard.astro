---
interface Props {
  slug: string
  title: string
  subtitle: string
  tags: string[]
  cover?: string | null
  category: string
  featured?: boolean
}

const { slug, title, subtitle, tags, cover, featured } = Astro.props
---

<a href={`/works/${slug}`} class="group block">
  <article class:list={[
    'bg-white rounded-lg border border-ink/5 overflow-hidden',
    'transition-all duration-300 ease-natural',
    'hover:shadow-lg hover:shadow-ink/5 hover:-translate-y-0.5',
  ]}>
    {cover && (
      <div class="aspect-[16/10] overflow-hidden bg-code-bg">
        <img src={cover} alt={title} class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500 ease-natural" loading="lazy" />
      </div>
    )}
    <div class="p-5">
      <div class="flex items-start justify-between gap-2 mb-2">
        <h3 class="font-display text-lg font-semibold tracking-tight group-hover:text-accent transition-colors">{title}</h3>
        {featured && <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-accent mt-2" title="Featured" />}
      </div>
      <p class="text-sm text-muted mb-3 line-clamp-2">{subtitle}</p>
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 4).map(tag => (
          <span class="text-xs px-2 py-0.5 bg-code-bg text-muted rounded">{tag}</span>
        ))}
      </div>
    </div>
  </article>
</a>
