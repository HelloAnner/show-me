---
const pathname = Astro.url.pathname
const links = [
  { href: '/about', label: 'About' },
  { href: '/works', label: 'Works' },
  { href: '/thinking', label: 'Thinking' },
  { href: '/journey', label: 'Journey' },
  { href: '/connect', label: 'Connect' },
]
---

<header class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-sm">
  <nav class="mx-auto max-w-content px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-display text-lg font-semibold tracking-tight text-ink hover:text-accent transition-colors">
      ShowMe
    </a>
    <ul class="flex items-center gap-8">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm tracking-wide transition-colors',
              pathname.startsWith(href)
                ? 'text-ink font-medium'
                : 'text-muted hover:text-ink',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
