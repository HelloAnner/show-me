---
import { ViewTransitions } from 'astro:transitions'
import '@/styles/global.css'

interface Props {
  title?: string
  description?: string
}

const { title = 'ShowMe', description = '构建工具，记录思考。' } = Astro.props
const pageTitle = title === 'ShowMe' ? title : `${title} — ShowMe`
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&family=Noto+Sans+SC:wght@400;500;600&family=Noto+Serif+SC:wght@400;600&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>
